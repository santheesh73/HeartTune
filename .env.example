# HeartTune Environment Variables
# For Next.js, copy these values into .env.local.
# For the legacy Vite setup, the VITE_* values below still work.

# App name shown in the browser
VITE_APP_NAME=HeartTune


# Frontend API base path. Use /api for local dev only if Vite is proxying requests.
# For static deployment, either:
# 1. leave this unset and the app will use `${VITE_SAAVN_API_URL}/api`, or
# 2. set this to the full API base like https://saavn.sumit.co/api
VITE_API_BASE_URL=/api

# JioSaavn API origin (used by Vite dev proxy and as the production fallback origin)
VITE_SAAVN_API_URL=https://saavn.sumit.co

# Supabase project configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Next.js public environment variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SAAVN_API_URL=https://saavn.sumit.co
