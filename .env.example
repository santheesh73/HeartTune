# HeartWave Environment Variables
# Copy this file to .env and update values as needed

# App name shown in the browser
VITE_APP_NAME=HeartWave

# Frontend API base path. Use /api for local dev only if Vite is proxying requests.
# For static deployment, either:
# 1. leave this unset and the app will use `${VITE_SAAVN_API_URL}/api`, or
# 2. set this to the full API base like https://saavn.sumit.co/api
VITE_API_BASE_URL=/api

# JioSaavn API origin (used by Vite dev proxy and as the production fallback origin)
VITE_SAAVN_API_URL=https://saavn.sumit.co
