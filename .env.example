# HeartTune Environment Variables
# Copy this file to .env.local for local development.
# Add the same keys in your hosting provider before deploying.

# Supabase project configuration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Public app URL used in Supabase email links. Example: https://your-hearttune.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JioSaavn API origin and browser API base.
# /api is proxied by next.config.mjs to NEXT_PUBLIC_SAAVN_API_URL.
NEXT_PUBLIC_SAAVN_API_URL=https://saavn.sumit.co
NEXT_PUBLIC_API_BASE_URL=/api

# Server-only API rate limiting. Configure these in Vercel project environment variables.
# Never prefix these with NEXT_PUBLIC_.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_REDIS_PREFIX=heartwave:rate-limit

# Optional: set to true in production if traffic should be blocked when Redis is unavailable.
RATE_LIMIT_FAIL_CLOSED=false

# Sentry monitoring. NEXT_PUBLIC_SENTRY_DSN enables browser reporting.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_ENABLE_LOGS=false
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENABLE_LOGS=false
SENTRY_SEND_DEFAULT_PII=false
NEXT_PUBLIC_APP_ENV=production
SENTRY_DISABLE_TELEMETRY=true

# Optional Sentry relay route (for example /monitoring). Leave empty locally.
SENTRY_TUNNEL_ROUTE=

# Optional Vercel build-time source map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=santheesh
SENTRY_PROJECT=hearttune
